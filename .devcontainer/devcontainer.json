{
    "name": "dbt Fusion Starter",
    "dockerFile": "Dockerfile",
    "customizations": {
        "codespaces": {
            "secrets": {
                "SNOWFLAKE_ACCOUNT": {
                    "description": "Snowflake account identifier, e.g. abc12345.us-east-1",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                },
                "SNOWFLAKE_USER": {
                    "description": "Your Snowflake username",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                },
                "SNOWFLAKE_PASSWORD": {
                    "description": "Your Snowflake password",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                },
                "SNOWFLAKE_DATABASE": {
                    "description": "Target Snowflake database",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                },
                "SNOWFLAKE_WAREHOUSE": {
                    "description": "Snowflake virtual warehouse name",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                },
                "SNOWFLAKE_SCHEMA": {
                    "description": "Dev schema name (defaults to 'dev' if not set)",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                },
                "SNOWFLAKE_ROLE": {
                    "description": "Snowflake role (optional)",
                    "documentationUrl": "https://docs.getdbt.com/docs/core/connect-data-platform/snowflake-setup"
                }
            }
        },
        "vscode": {
            "extensions": [
                "dbtLabsInc.dbt"
            ],
            "settings": {
                "dbt.profilesDirOverride": "${workspaceFolder}",
                "workbench.editorAssociations": {
                    "*.md": "vscode.markdown.preview.editor"
                }
            }
        }
    },
    "postCreateCommand": "dbt deps",
    "postStartCommand": "dbt system update",
    "hostRequirements": {
        "cpus": 2,
        "memory": "4gb",
        "storage": "32gb"
    }
}
